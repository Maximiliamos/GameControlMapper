<Window x:Class="GameControlMapper.TouchTestHarness.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Game Control Mapper — Ручная проверка версии 1.0" Width="1250" Height="820" Background="#101827" Foreground="White" TouchDown="OnTouchDown" TouchMove="OnTouchMove" TouchUp="OnTouchUp" GotKeyboardFocus="OnFocusChanged" LostKeyboardFocus="OnFocusChanged">
 <Grid Margin="10"><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
  <Grid Grid.Column="0"><Border Background="#172033" BorderBrush="#4CC9F0" BorderThickness="2" CornerRadius="8"/><Canvas x:Name="TouchCanvas" Background="Transparent"/><TextBlock Text="СЕНСОРНАЯ РАБОЧАЯ ОБЛАСТЬ" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,14" FontSize="18" Foreground="#8EA8C9" IsHitTestVisible="False"/></Grid>
  <Grid Grid.Column="1" Margin="12,0,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="2*"/><RowDefinition Height="3*"/></Grid.RowDefinitions>
   <StackPanel><TextBlock x:Name="FocusText" FontWeight="Bold"/><TextBlock x:Name="WindowText" TextWrapping="Wrap"/><UniformGrid Columns="4"><TextBlock x:Name="ActiveText"/><TextBlock x:Name="DownText"/><TextBlock x:Name="MoveText"/><TextBlock x:Name="UpText"/></UniformGrid><TextBlock x:Name="MaxText"/><WrapPanel><Button Content="Очистить журнал" Click="ClearLog"/><Button Content="Сбросить" Click="Reset"/><Button Content="Проверить контакты" Click="CheckActive"/><Button Content="Экспорт старого отчёта" Click="Export"/></WrapPanel></StackPanel>
   <ListBox Grid.Row="1" x:Name="EventLog" FontFamily="Consolas" FontSize="11" Background="#0B1220" Foreground="#D9E7F5"/>
   <GroupBox Grid.Row="2" Header="Ручная проверка версии 1.0" Foreground="White" Margin="0,8,0,0"><DockPanel><StackPanel DockPanel.Dock="Bottom"><TextBlock x:Name="EvidenceText" Foreground="#FCD34D" TextWrapping="Wrap"/><TextBox x:Name="ScenarioComment" MinHeight="44" TextWrapping="Wrap" ToolTip="Комментарий обязателен для FAIL"/><WrapPanel><Button x:Name="GuidedPassButton" Content="PASS" Click="GuidedPass"/><Button Content="FAIL" Click="GuidedFail"/><Button Content="NOT AVAILABLE" Click="GuidedUnavailable"/><Button Content="Экспорт JSON + TXT" Click="ExportGuided"/></WrapPanel></StackPanel><ListBox x:Name="ScenarioList" DisplayMemberPath="Name" SelectionChanged="ScenarioSelectionChanged"/></DockPanel></GroupBox>
  </Grid>
 </Grid>
</Window>
