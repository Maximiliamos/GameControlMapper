<Window x:Class="GameControlMapper.UI.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:GameControlMapper.ViewModels"
        Title="Схема управления"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        IsHitTestVisible="False">
    <Viewbox Stretch="Fill" StretchDirection="Both">
        <Canvas Width="{Binding CurrentProfile.ResolutionWidth}"
                Height="{Binding CurrentProfile.ResolutionHeight}"
                Background="#01000000">
            <ItemsControl Width="{Binding CurrentProfile.ResolutionWidth}"
                          Height="{Binding CurrentProfile.ResolutionHeight}"
                          ItemsSource="{Binding Bindings}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:BindingViewModel}">
                        <Grid Width="{Binding Width}" Height="{Binding Height}">
                            <Border Background="{Binding Color, Converter={StaticResource HexBrushConverter}}"
                                    BorderBrush="#F8FAFC"
                                    BorderThickness="2"
                                    CornerRadius="10"
                                    Opacity="{Binding Opacity}" />
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="5">
                                <TextBlock Text="{Binding DisplayHotkey}"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="18"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#F0F7FF"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Canvas>
    </Viewbox>
</Window>
