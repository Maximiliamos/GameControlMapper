<Window x:Class="GameControlMapper.UI.Views.ControlEditorOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:GameControlMapper.ViewModels"
        Title="Редактор управления поверх игры"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="OverlayPanel" TargetType="Border">
            <Setter Property="Background" Value="#F20F1724" />
            <Setter Property="BorderBrush" Value="#52657F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.45" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="3" />
        </Style>

        <Style x:Key="OverlayContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#F5111A28" />
            <Setter Property="BorderBrush" Value="#52657F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="7">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.45" />
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#34445B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- The game remains visible below this independently adjustable dim layer. -->
        <Border Background="#FF060B12" Opacity="{Binding OverlayDimOpacity}" />

        <!-- Profile space is stretched exactly like the production touch transformer. -->
        <Viewbox Stretch="Fill" StretchDirection="Both">
            <Canvas x:Name="ProfileCanvas"
                    Width="{Binding ProfileWidth}"
                    Height="{Binding ProfileHeight}"
                    Background="#01000000"
                    PreviewMouseLeftButtonDown="ProfileCanvas_PreviewMouseLeftButtonDown"
                    PreviewMouseRightButtonDown="ProfileCanvas_PreviewMouseRightButtonDown">
                <ItemsControl Width="{Binding ProfileWidth}"
                              Height="{Binding ProfileHeight}"
                              ItemsSource="{Binding Bindings}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:BindingViewModel}">
                            <Grid Width="{Binding Width}"
                                  Height="{Binding Height}"
                                  ToolTip="{Binding Comment}"
                                  PreviewMouseRightButtonDown="Binding_PreviewMouseRightButtonDown">
                                <Border Background="{Binding Color, Converter={StaticResource HexBrushConverter}}"
                                        BorderBrush="#E6F2FF"
                                        BorderThickness="2"
                                        CornerRadius="12"
                                        Opacity="{Binding Opacity}" />

                                <Thumb Cursor="SizeAll"
                                       Background="Transparent"
                                       DragDelta="MoveThumb_DragDelta"
                                       PreviewMouseLeftButtonDown="Binding_PreviewMouseLeftButtonDown">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>

                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="7"
                                            IsHitTestVisible="False">
                                    <TextBlock Text="{Binding DisplayHotkey}"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               TextAlignment="Center" />
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#EDF6FF"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Border BorderBrush="#24D5FF"
                                        BorderThickness="4"
                                        CornerRadius="12"
                                        Margin="-4"
                                        IsHitTestVisible="False"
                                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}" />

                                <Thumb Width="22"
                                       Height="22"
                                       Margin="0,0,-9,-9"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Cursor="SizeNWSE"
                                       DragDelta="ResizeThumb_DragDelta"
                                       PreviewMouseLeftButtonDown="Binding_PreviewMouseLeftButtonDown"
                                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#24D5FF"
                                                    BorderBrush="White"
                                                    BorderThickness="2"
                                                    CornerRadius="11" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
        </Viewbox>

        <Border Style="{StaticResource OverlayPanel}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="16"
                Padding="12,9">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Margin="0,0,20,0">
                    <TextBlock Text="Редактор управления"
                               FontSize="16"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding ProfileName, StringFormat='Профиль: {0}'}"
                               Foreground="#9FB0C7"
                               FontSize="12" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="AddControlButton"
                            Style="{StaticResource CompactButton}"
                            Content="＋ Добавить"
                            Click="AddControlButton_Click"
                            ToolTip="Выберите тип и добавьте элемент в центр поля" />
                    <Button Style="{StaticResource CompactButton}"
                            Content="⧉ Дублировать"
                            Click="DuplicateButton_Click"
                            IsEnabled="{Binding CanDuplicateSelection}" />
                    <Button Style="{StaticResource CompactButton}"
                            Content="⌫ Удалить"
                            Click="DeleteButton_Click"
                            IsEnabled="{Binding CanDeleteSelection}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="Затемнение" Margin="0,0,7,0" Foreground="#C9D7E8" />
                    <Slider Width="105"
                            Minimum="0.05"
                            Maximum="0.72"
                            TickFrequency="0.05"
                            Value="{Binding OverlayDimOpacity}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Style="{StaticResource OverlayPanel}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="16"
                Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource CompactButton}"
                        Content="✓ Сохранить"
                        Background="#087EA4"
                        BorderBrush="#24D5FF"
                        Click="SaveButton_Click"
                        ToolTip="Проверить и сохранить изменения профиля" />
                <Button Style="{StaticResource CompactButton}"
                        Content="Отмена  Esc"
                        Click="CancelButton_Click"
                        ToolTip="Закрыть редактор, не применяя изменения" />
            </StackPanel>
        </Border>

        <Border HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="16,92,16,16"
                Padding="9,6"
                Background="#D90A101A"
                CornerRadius="5"
                IsHitTestVisible="False">
            <TextBlock Text="Правый клик по пустой области — добавить управление  •  Перетащите элемент — переместить  •  Голубой маркер — изменить размер"
                       Foreground="#D8E5F5"
                       FontSize="12" />
        </Border>

        <Border Width="330"
                MaxHeight="650"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="18,86,18,18"
                Style="{StaticResource OverlayPanel}"
                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <DockPanel Margin="0,0,0,9">
                        <TextBlock Text="Настройка элемента"
                                   FontSize="16"
                                   FontWeight="Bold" />
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource CompactButton}"
                                Content="×"
                                Width="34"
                                Padding="0"
                                Click="ClosePropertiesButton_Click"
                                ToolTip="Снять выделение" />
                    </DockPanel>

                    <Border Background="#263348" CornerRadius="6" Padding="9" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Тип действия" Foreground="#94A9C2" FontSize="11" />
                            <TextBlock Text="{Binding SelectedBinding.Kind, Converter={StaticResource BindingKindLabelConverter}}"
                                       FontWeight="SemiBold"
                                       FontSize="14" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Название" Foreground="#AFC0D5" />
                    <TextBox Text="{Binding SelectedBinding.Name, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Короткое понятное название элемента" />

                    <TextBlock Text="Клавиша или кнопка мыши" Foreground="#AFC0D5" />
                    <TextBox x:Name="HotkeyTextBox"
                             Text="{Binding SelectedBinding.Hotkey, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding SelectedBinding.IsHotkeyReadOnly}"
                             GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                             PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                             ToolTip="Щёлкните поле и нажмите нужную клавишу. Для мыши: MouseLeft, MouseRight или MouseMiddle." />
                    <TextBlock Text="Щёлкните поле и нажмите клавишу. Для мыши можно ввести MouseLeft или MouseRight."
                               Foreground="#8395AD"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,-6,0,9" />
                    <UniformGrid Columns="3" Margin="0,-3,0,9">
                        <Button Style="{StaticResource CompactButton}"
                                Content="ЛКМ"
                                Tag="MouseLeft"
                                IsEnabled="{Binding SelectedBinding.CanEditHotkey}"
                                Click="MouseHotkeyButton_Click"
                                ToolTip="Левая кнопка мыши" />
                        <Button Style="{StaticResource CompactButton}"
                                Content="ПКМ"
                                Tag="MouseRight"
                                IsEnabled="{Binding SelectedBinding.CanEditHotkey}"
                                Click="MouseHotkeyButton_Click"
                                ToolTip="Правая кнопка мыши" />
                        <Button Style="{StaticResource CompactButton}"
                                Content="СКМ"
                                Tag="MouseMiddle"
                                IsEnabled="{Binding SelectedBinding.CanEditHotkey}"
                                Click="MouseHotkeyButton_Click"
                                ToolTip="Средняя кнопка мыши" />
                    </UniformGrid>

                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Text="X" Foreground="#AFC0D5" />
                            <TextBox Text="{Binding SelectedBinding.X, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="5,0,0,0">
                            <TextBlock Text="Y" Foreground="#AFC0D5" />
                            <TextBox Text="{Binding SelectedBinding.Y, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Text="Ширина" Foreground="#AFC0D5" />
                            <TextBox Text="{Binding SelectedBinding.Width, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="5,0,0,0">
                            <TextBlock Text="Высота" Foreground="#AFC0D5" />
                            <TextBox Text="{Binding SelectedBinding.Height, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="Видимость элемента" Foreground="#AFC0D5" />
                    <Slider Minimum="0.12"
                            Maximum="1"
                            TickFrequency="0.05"
                            Value="{Binding SelectedBinding.Opacity}"
                            Margin="0,3,0,12" />

                    <StackPanel Visibility="{Binding SelectedBinding.UsesDuration, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Длительность удержания / свайпа, мс" Foreground="#AFC0D5" />
                        <TextBox Text="{Binding SelectedBinding.HoldMilliseconds, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <CheckBox Content="Элемент активен"
                              IsChecked="{Binding SelectedBinding.IsActive}"
                              Visibility="{Binding SelectedBinding.CanToggleActive, Converter={StaticResource BoolToVisibility}}"
                              Margin="0,2,0,10" />

                    <TextBlock Text="Подсказка" Foreground="#AFC0D5" />
                    <TextBox MinHeight="58"
                             Text="{Binding SelectedBinding.Comment, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True" />

                    <TextBlock Text="Камера — единственный системный элемент: её нельзя удалить или дублировать."
                               Foreground="#8FA3BC"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
