<Window x:Class="GameControlMapper.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:GameControlMapper.ViewModels"
        Title="Game Control Mapper — настройка управления"
        Width="1560"
        Height="960"
        MinWidth="1180"
        MinHeight="740"
        Background="{StaticResource ShellBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        PreviewMouseDown="Window_PreviewMouseDown"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="286" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="390" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Background="#F20C1119"
                BorderBrush="#2A384C"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="16,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,14,0" VerticalAlignment="Center">
                        <TextBlock Text="Game Control Mapper" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Схемы управления для сенсорных игр"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12" />
                    </StackPanel>
                    <Button Content="＋  Новый"
                            Style="{StaticResource CompactButton}"
                            Command="{Binding NewProfileCommand}"
                            ToolTip="Создать новый профиль на основе схемы Tanks Blitz" />
                    <Button Content="✓  Сохранить"
                            Style="{StaticResource CompactButton}"
                            Command="{Binding SaveProfileCommand}"
                            ToolTip="Сохранить текущую схему и резервную копию предыдущей версии" />
                    <Button Content="Импорт" Style="{StaticResource CompactButton}" Command="{Binding ImportProfileCommand}" />
                    <Button Content="Экспорт" Style="{StaticResource CompactButton}" Command="{Binding ExportProfileCommand}" />
                    <Button Content="Диагностика" Style="{StaticResource CompactButton}" Command="{Binding ExportDiagnosticsCommand}" />
                    <Button Content="XVM"
                            Style="{StaticResource CompactButton}"
                            Command="{Binding OpenBlitzXvmCommand}"
                            ToolTip="Запустить Blitz XVM или показать его уже открытое окно. Программа статистики работает отдельно от сенсорного ввода." />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,9,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding BetaVersion}"
                                   Foreground="#FBBF24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding IsMappingActive, Converter={StaticResource BooleanLabelConverter}}"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Right"
                                   FontSize="12" />
                    </StackPanel>
                    <Button Content="▶ F8 Запустить"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ActivateCommand}"
                            Background="#0E7490"
                            BorderBrush="#22D3EE"
                            ToolTip="Начать управление выбранным окном" />
                    <Button Content="■ F9 Остановить"
                            Style="{StaticResource CompactButton}"
                            Command="{Binding DeactivateCommand}"
                            ToolTip="Немедленно завершить все активные касания" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#F2121824"
                BorderBrush="#2A384C"
                BorderThickness="0,0,1,0"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Целевое окно" Style="{StaticResource SectionTitle}" />
                <StackPanel Grid.Row="1">
                    <TextBlock Text="{Binding TargetWindowStatus}"
                               TextWrapping="Wrap"
                               Foreground="#FCD34D"
                               Margin="0,5" />
                    <ComboBox ItemsSource="{Binding TargetWindows}"
                              SelectedItem="{Binding SelectedTargetWindow, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              ToolTip="Выберите окно Android Device или окно игры" />
                    <Button Content="↻ Обновить список окон"
                            Style="{StaticResource CompactButton}"
                            Command="{Binding RefreshWindowsCommand}"
                            ToolTip="Нажмите после запуска игры или эмулятора" />
                </StackPanel>

                <Border Grid.Row="2" Style="{StaticResource Card}"
                        Margin="0,10,0,12"
                        Padding="9"
                        Background="#18283A"
                        BorderBrush="#38617E">
                    <StackPanel>
                         <TextBlock Text="Редактор управления" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Игра останется видна, а схема откроется полупрозрачным слоем поверх неё."
                                   Margin="0,4,0,8"
                                   Foreground="#B5C5D9"
                                   TextWrapping="Wrap"
                                   FontSize="12" />
                        <Button Content="✦ Редактировать поверх игры"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding OpenControlEditorCommand}"
                                MinHeight="48"
                                FontSize="14"
                                Background="#087EA4"
                                BorderBrush="#24D5FF"
                                ToolTip="Открыть удобный редактор. Также доступно по F11." />
                        <TextBlock Text="F11 — открыть редактор"
                                   HorizontalAlignment="Center"
                                   Foreground="#8296AF"
                                   FontSize="12" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="Профили" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="Выберите схему для игры"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,2,0,8" />
                    <ListBox ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfileName, Mode=TwoWay}" />
                </StackPanel>

                <Button Grid.Row="4"
                        Content="Удалить выбранный профиль"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteProfileCommand}"
                        ToolTip="Удаление нельзя отменить" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1" Background="#660B0F15">
            <Grid.RowDefinitions>
                <RowDefinition Height="116" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="#F2111824"
                    BorderBrush="#2A384C"
                    BorderThickness="0,0,0,1"
                    Padding="10">
                <StackPanel>
                    <WrapPanel>
                        <ComboBox Width="205"
                                  ItemsSource="{Binding BindingKinds}"
                                  SelectedItem="{Binding NewBindingKind}"
                                  ToolTip="Выберите тип элемента, затем нажмите «Добавить»">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource BindingKindLabelConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="＋ Добавить"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddBindingCommand}"
                                ToolTip="Добавить элемент в рабочее поле" />
                        <Button Content="Копировать" Command="{Binding CopyBindingCommand}" />
                        <Button Content="Вставить" Command="{Binding PasteBindingCommand}" />
                        <Button Content="Дублировать" Command="{Binding DuplicateBindingCommand}" />
                        <Button Content="Удалить" Command="{Binding DeleteBindingCommand}" />
                    </WrapPanel>
                    <WrapPanel>
                        <Button Content="Выбрать область на экране"
                                Command="{Binding SelectAreaCommand}"
                                ToolTip="Обведите сенсорную кнопку в целевом окне" />
                        <Button Content="Указать центр кнопки"
                                Command="{Binding PickCenterCommand}" />
                        <TextBlock Text="Рекомендуется редактор поверх игры: правый клик добавляет элемент точно в нужном месте."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="10,0,0,0" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Background="#0E1520" ClipToBounds="True">
                <Viewbox Stretch="Uniform" StretchDirection="Both" Margin="10">
                    <Canvas Width="{Binding CurrentProfile.ResolutionWidth}"
                            Height="{Binding CurrentProfile.ResolutionHeight}"
                            Background="#131D2B"
                            MouseDown="EditorCanvas_MouseDown">
                        <ItemsControl Width="{Binding CurrentProfile.ResolutionWidth}"
                                      Height="{Binding CurrentProfile.ResolutionHeight}"
                                      ItemsSource="{Binding Bindings}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:BindingViewModel}">
                                    <Grid Width="{Binding Width}" Height="{Binding Height}" ToolTip="{Binding Comment}">
                                        <Thumb DragDelta="MoveThumb_DragDelta"
                                               PreviewMouseLeftButtonDown="BindingThumb_PreviewMouseLeftButtonDown">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="{Binding Color, Converter={StaticResource HexBrushConverter}}"
                                                            BorderBrush="White"
                                                            BorderThickness="2"
                                                            CornerRadius="9"
                                                            Opacity="{Binding Opacity}">
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                                            <TextBlock Text="{Binding DisplayHotkey}"
                                                                       FontWeight="Bold"
                                                                       FontSize="17"
                                                                       HorizontalAlignment="Center" />
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="11"
                                                                       TextAlignment="Center"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                        <Border BorderBrush="#24D5FF"
                                                BorderThickness="4"
                                                CornerRadius="9"
                                                Margin="-4"
                                                IsHitTestVisible="False"
                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}" />
                                        <Thumb Width="20"
                                               Height="20"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Bottom"
                                               Cursor="SizeNWSE"
                                               DragDelta="ResizeThumb_DragDelta"
                                               PreviewMouseLeftButtonDown="BindingThumb_PreviewMouseLeftButtonDown"
                                               Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="#24D5FF"
                                                            BorderBrush="White"
                                                            BorderThickness="2"
                                                            CornerRadius="10" />
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </Viewbox>

                <Border HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="12"
                        Padding="8,5"
                        Background="#D90D1520"
                        CornerRadius="5"
                        IsHitTestVisible="False">
                    <TextBlock Text="Перетаскивание — переместить  •  Голубой маркер — изменить размер"
                               Foreground="#B9C9DB"
                               FontSize="12" />
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                Grid.Column="2"
                Background="#F2121824"
                BorderBrush="#2A384C"
                BorderThickness="1,0,0,0"
                Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Инспектор" FontSize="19" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <Border Style="{StaticResource Card}" Background="#122B36" BorderBrush="#1F6C83" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Режим мыши" FontWeight="SemiBold" Foreground="#7DD3FC" />
                            <TextBlock Text="{Binding MouseModeStatus}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            <TextBlock Text="Ctrl переключает режим. В свободном режиме ЛКМ доступна меню игры."
                                       Style="{StaticResource Caption}" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                    <Expander Header="Как настроить управление" IsExpanded="False" Margin="0,0,0,12">
                        <Border Background="#202938" CornerRadius="6" Padding="10">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#D7E3F4"
                                       Text="1. Запустите игру и выберите её окно.&#10;2. Нажмите «Редактировать поверх игры».&#10;3. Щёлкните правой кнопкой по пустой области.&#10;4. Выберите действие, перетащите его и задайте клавишу.&#10;5. Сохраните схему и нажмите F8.&#10;&#10;Ctrl включает обзор камерой; повторный Ctrl возвращает мышь.&#10;F9 всегда останавливает управление." />
                        </Border>
                    </Expander>

                    <Expander Header="Статистика Blitz XVM" IsExpanded="False" Margin="0,0,0,12">
                        <Border Background="#202938" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Text="{Binding OlenemerStatus}" Foreground="#93C5FD" />
                                <TextBlock Text="{Binding OlenemerAccountSummary}" TextWrapping="Wrap" Margin="0,5,0,0" />
                                <TextBlock Text="{Binding OlenemerLastBattleSummary}" TextWrapping="Wrap" Margin="0,5,0,8" />
                                <UniformGrid Columns="2">
                                    <Button Content="Обновить" Command="{Binding RefreshOlenemerStatsCommand}" />
                                    <Button Content="Открыть XVM" Command="{Binding OpenBlitzXvmCommand}" />
                                </UniformGrid>
                                <TextBlock Text="Читаются только агрегаты account_stats.json и итог battle_result.json. DLL и список игроков не загружаются."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </Expander>

                    <Expander Header="Камера и чувствительность" IsExpanded="True" Margin="0,0,0,12">
                        <Border Background="#202938" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Ctrl включает боевой режим: обзор и ЛКМ «Огонь». Повторный Ctrl возвращает свободную мышь. Изменения сохраняются кнопкой «Сохранить»."
                                           TextWrapping="Wrap"
                                           Foreground="#D7E3F4"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Горизонтальная чувствительность" />
                                <DockPanel>
                                    <TextBox DockPanel.Dock="Right" Width="72"
                                             Text="{Binding CurrentProfile.Camera.SensitivityX, Converter={StaticResource FlexibleDoubleConverter}, UpdateSourceTrigger=LostFocus}" />
                                    <Slider Minimum="0.1" Maximum="3" TickFrequency="0.05"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding CurrentProfile.Camera.SensitivityX}"
                                            ToolTip="Можно ввести 0,5 или 0.5. Значение 1,0 соответствует движению один к одному." />
                                </DockPanel>
                                <TextBlock Text="Вертикальная чувствительность" Margin="0,6,0,0" />
                                <DockPanel>
                                    <TextBox DockPanel.Dock="Right" Width="72"
                                             Text="{Binding CurrentProfile.Camera.SensitivityY, Converter={StaticResource FlexibleDoubleConverter}, UpdateSourceTrigger=LostFocus}" />
                                    <Slider Minimum="0.1" Maximum="3" TickFrequency="0.05"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding CurrentProfile.Camera.SensitivityY}" />
                                </DockPanel>
                                <TextBlock Text="Сглаживание" Margin="0,6,0,0" />
                                <DockPanel>
                                    <TextBox DockPanel.Dock="Right" Width="72"
                                             Text="{Binding CurrentProfile.Camera.Smooth, Converter={StaticResource FlexibleDoubleConverter}, UpdateSourceTrigger=LostFocus}" />
                                    <Slider Minimum="0" Maximum="0.2" TickFrequency="0.01"
                                            Value="{Binding CurrentProfile.Camera.Smooth}"
                                            ToolTip="0 — прямой и наиболее отзывчивый обзор; увеличивайте понемногу, если движение кажется резким" />
                                </DockPanel>
                                <UniformGrid Columns="2" Margin="0,8,0,0">
                                    <CheckBox Content="Инвертировать X" IsChecked="{Binding CurrentProfile.Camera.InvertX}" />
                                    <CheckBox Content="Инвертировать Y" IsChecked="{Binding CurrentProfile.Camera.InvertY}" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <TextBlock Text="Параметры элемента" Style="{StaticResource SectionTitle}" Margin="0,4,0,10" />
                    <TextBlock Text="Название профиля" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Понятное название игры или схемы" />

                    <TextBlock Text="Название элемента" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox Text="{Binding SelectedBinding.Name, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Действие" Foreground="{StaticResource MutedTextBrush}" />
                    <ComboBox ItemsSource="{Binding BindingKinds}"
                              SelectedItem="{Binding SelectedBinding.Kind}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource BindingKindLabelConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Клавиша или кнопка мыши" Foreground="{StaticResource MutedTextBrush}" />
                    <DockPanel LastChildFill="True">
                        <Button x:Name="RecordHotkeyButton"
                                DockPanel.Dock="Right"
                                Width="82"
                                Content="● REC"
                                IsEnabled="{Binding SelectedBinding.CanEditHotkey}"
                                Click="RecordHotkeyButton_Click"
                                ToolTip="Нажмите REC, затем нужную клавишу или кнопку мыши" />
                        <TextBox x:Name="HotkeyTextBox"
                                 Text="{Binding SelectedBinding.Hotkey, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding SelectedBinding.IsHotkeyReadOnly}"
                                 GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                 PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                 ToolTip="Примеры: Q, Space, LeftCtrl, MouseLeft, MouseRight, WASD" />
                    </DockPanel>
                    <TextBlock Text="Нажмите REC, а затем нужную клавишу. Для сочетания удерживайте Ctrl, Shift или Alt."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,-6,0,9" />

                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,0,6,0">
                            <TextBlock Text="X" />
                            <TextBox Text="{Binding SelectedBinding.X, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="6,0,0,0">
                            <TextBlock Text="Y" />
                            <TextBox Text="{Binding SelectedBinding.Y, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,6,0">
                            <TextBlock Text="Ширина" />
                            <TextBox Text="{Binding SelectedBinding.Width, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="6,0,0,0">
                            <TextBlock Text="Высота" />
                            <TextBox Text="{Binding SelectedBinding.Height, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="Цвет элемента" />
                    <TextBox Text="{Binding SelectedBinding.Color, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Видимость элемента" />
                    <Slider Minimum="0.05" Maximum="1" Value="{Binding SelectedBinding.Opacity}" Margin="0,3,0,10" />
                    <TextBlock Text="Длительность, мс" />
                    <TextBox Text="{Binding SelectedBinding.HoldMilliseconds, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox Content="Элемент активен" IsChecked="{Binding SelectedBinding.IsActive}" Margin="0,2,0,10" />
                    <TextBlock Text="Комментарий / подсказка" />
                    <TextBox MinHeight="64"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Text="{Binding SelectedBinding.Comment, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="3"
                Background="#DD0D1118"
                BorderBrush="#273244"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <Expander Header="Журнал работы и диагностика" IsExpanded="False">
                <DockPanel Margin="0,6,0,4" Height="132">
                    <Button DockPanel.Dock="Top" HorizontalAlignment="Right"
                            Style="{StaticResource CompactButton}"
                            Content="Копировать журнал"
                            Command="{Binding CopyLogsCommand}" />
                    <ListBox ItemsSource="{Binding Logs}" FontFamily="Consolas" FontSize="12" />
                </DockPanel>
            </Expander>
        </Border>
    </Grid>
</Window>
