<Window x:Class="GameControlMapper.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:GameControlMapper.ViewModels"
        mc:Ignorable="d"
        Title="Управление играми"
        Width="1440"
        Height="900"
        MinWidth="1120"
        MinHeight="720"
        Background="{StaticResource ShellBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        Opacity="1"
        Topmost="False"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
            <RowDefinition Height="118" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#DD0D1118" BorderBrush="#273244" BorderThickness="0,0,0,1">
            <DockPanel Margin="12,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="Управление играми" FontSize="18" FontWeight="SemiBold" Margin="0,0,18,0" />
                    <Button Content="Создать" Command="{Binding NewProfileCommand}" />
                    <Button Content="Сохранить" Command="{Binding SaveProfileCommand}" />
                    <Button Content="Импорт" Command="{Binding ImportProfileCommand}" />
                    <Button Content="Экспорт" Command="{Binding ExportProfileCommand}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ResolutionText}" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,14,0" />
                    <TextBlock Text="{Binding IsMappingActive, Converter={StaticResource BooleanLabelConverter}}" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" />
                    <Button Content="F8 — Запустить" Command="{Binding ActivateCommand}" />
                    <Button Content="F9 — Остановить" Command="{Binding DeactivateCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="#D9171B24" BorderBrush="#273244" BorderThickness="0,0,1,0" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Профили" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" />
                <StackPanel DockPanel.Dock="Bottom">
                    <Button Content="Удалить профиль" Command="{Binding DeleteProfileCommand}" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfileName, Mode=TwoWay}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="6,7" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1" Background="#660B0F15">
            <Grid.RowDefinitions>
                <RowDefinition Height="96" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#CC111722" BorderBrush="#273244" BorderThickness="0,0,0,1">
                <DockPanel Margin="10,4" LastChildFill="False">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Top">
                        <ComboBox Width="180" ItemsSource="{Binding BindingKinds}" SelectedItem="{Binding NewBindingKind}">
                            <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource BindingKindLabelConverter}}" Foreground="#111827" /></DataTemplate></ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="Добавить зону" Command="{Binding AddBindingCommand}" />
                        <Button Content="Копировать" Command="{Binding CopyBindingCommand}" />
                        <Button Content="Вставить" Command="{Binding PasteBindingCommand}" />
                        <Button Content="Дублировать" Command="{Binding DuplicateBindingCommand}" />
                        <Button Content="Удалить" Command="{Binding DeleteBindingCommand}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Выбрать область" Command="{Binding SelectAreaCommand}" />
                        <Button Content="Указать центр" Command="{Binding PickCenterCommand}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#33070A0F">
                <Grid>
                    <Canvas Width="1920"
                            Height="1080"
                            MouseDown="EditorCanvas_MouseDown">
                        <Canvas.Background>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,32,32" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="#30101722">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,32,32" />
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="#1D2838" Thickness="1" />
                                            </GeometryDrawing.Pen>
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <LineGeometry StartPoint="0,0" EndPoint="32,0" />
                                                    <LineGeometry StartPoint="0,0" EndPoint="0,32" />
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Canvas.Background>

                        <ItemsControl ItemsSource="{Binding Bindings}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:BindingViewModel}">
                                    <Grid Width="{Binding Width}" Height="{Binding Height}">
                                        <Thumb DragDelta="MoveThumb_DragDelta"
                                               PreviewMouseLeftButtonDown="BindingThumb_PreviewMouseLeftButtonDown">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="{Binding Color, Converter={StaticResource HexBrushConverter}}"
                                                            BorderBrush="#F8FAFC"
                                                            BorderThickness="2"
                                                            CornerRadius="4"
                                                            Opacity="{Binding Opacity}">
                                                        <Grid>
                                                            <Ellipse Width="8" Height="8" Fill="#F8FAFC" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6">
                                                                <TextBlock Text="{Binding Hotkey}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" />
                                                                <TextBlock Text="{Binding Name}" FontSize="11" HorizontalAlignment="Center" Foreground="#F8FAFC" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                        <Thumb Width="15"
                                               Height="15"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Bottom"
                                               Cursor="SizeNWSE"
                                               DragDelta="ResizeThumb_DragDelta"
                                               PreviewMouseLeftButtonDown="BindingThumb_PreviewMouseLeftButtonDown">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="#F8FAFC" BorderBrush="#0F172A" BorderThickness="1" />
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </Grid>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="1" Grid.Column="2" Background="#D9171B24" BorderBrush="#273244" BorderThickness="1,0,0,0" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Свойства" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Название профиля" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Название зоны" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox Text="{Binding SelectedBinding.Name, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Тип действия" Foreground="{StaticResource MutedTextBrush}" />
                    <ComboBox ItemsSource="{Binding BindingKinds}" SelectedItem="{Binding SelectedBinding.Kind}" />

                    <TextBlock Text="Клавиша" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox Text="{Binding SelectedBinding.Hotkey, UpdateSourceTrigger=PropertyChanged}" />

                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,0,6,0">
                            <TextBlock Text="X" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBox Text="{Binding SelectedBinding.X, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="6,0,0,0">
                            <TextBlock Text="Y" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBox Text="{Binding SelectedBinding.Y, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,6,0">
                            <TextBlock Text="Ширина" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBox Text="{Binding SelectedBinding.Width, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="6,0,0,0">
                            <TextBlock Text="Высота" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBox Text="{Binding SelectedBinding.Height, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="Цвет" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox Text="{Binding SelectedBinding.Color, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Прозрачность" Foreground="{StaticResource MutedTextBrush}" />
                    <Slider Minimum="0.05" Maximum="1" Value="{Binding SelectedBinding.Opacity}" TickFrequency="0.05" />

                    <TextBlock Text="Удержание, мс" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox Text="{Binding SelectedBinding.HoldMilliseconds, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Задержка, мс" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox Text="{Binding SelectedBinding.DelayMilliseconds, UpdateSourceTrigger=PropertyChanged}" />

                    <CheckBox Content="Зона активна" IsChecked="{Binding SelectedBinding.IsActive}" Foreground="{StaticResource TextBrush}" Margin="0,3,0,10" />
                    <CheckBox Content="Обычный ввод Windows" IsChecked="{Binding SelectedBinding.UseNativeInput}" Foreground="{StaticResource TextBrush}" Margin="0,3,0,10" />
                    <CheckBox Content="Повторять" IsChecked="{Binding SelectedBinding.Repeat}" Foreground="{StaticResource TextBrush}" Margin="0,3,0,10" />

                    <TextBlock Text="Приоритет" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox Text="{Binding SelectedBinding.Priority, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Комментарий" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox MinHeight="70" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding SelectedBinding.Comment, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#DD0D1118" BorderBrush="#273244" BorderThickness="0,1,0,0" Padding="12,8">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top">
                    <TextBlock Text="Журнал работы" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <Button DockPanel.Dock="Right" Content="Копировать журнал" Command="{Binding CopyLogsCommand}" Margin="0,0,0,6" />
                </DockPanel>
                <ListBox ItemsSource="{Binding Logs}" BorderThickness="0" FontFamily="Consolas" FontSize="12" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
