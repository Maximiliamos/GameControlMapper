<Window x:Class="GameControlMapper.UI.Views.TouchDebugOverlay" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Диагностика касаний" WindowStyle="None" AllowsTransparency="True" Background="Transparent" Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize" Width="340" Height="400" Left="10" Top="10" IsHitTestVisible="False">
 <Border Background="#D0202020" CornerRadius="8" Padding="16"><StackPanel>
  <TextBlock Text="Диагностика касаний" FontWeight="Bold" FontSize="18" Foreground="White" Margin="0,0,0,16"/>
  <ItemsControl ItemsSource="{Binding Contacts}"><ItemsControl.ItemTemplate><DataTemplate><StackPanel Margin="0,2"><TextBlock Foreground="White"><Run Text="ID "/><Run Text="{Binding ContactId}"/><Run Text=" — "/><Run Text="{Binding OwnerType}"/><Run Text=" — "/><Run Text="{Binding State}"/></TextBlock><TextBlock Foreground="#AAB7C4" FontSize="11" Text="{Binding BindingName}"/></StackPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
  <Separator Background="#40FFFFFF" Margin="0,16"/><TextBlock Text="Частота кадров:" Foreground="White"/><TextBlock Text="{Binding InjectedFps, StringFormat='{}{0:F0} Hz'}" FontSize="20" FontWeight="Bold" Foreground="#3B82F6"/>
 </StackPanel></Border>
</Window>
